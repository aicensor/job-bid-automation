# OpenRouter - Single API for all models (Claude, GPT, Gemini, etc.)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary model for resume rewriting (best natural prose)
PRIMARY_MODEL=anthropic/claude-sonnet-4

# Fallback models
FALLBACK_MODEL_1=openai/gpt-4o
FALLBACK_MODEL_2=google/gemini-2.0-flash-001

# Embedding model for semantic scoring
EMBEDDING_MODEL=openai/text-embedding-3-small

# Serper.dev — Google Search API for external job link resolution
SERPER_API_KEY=your-serper-api-key

# LinkedIn Bot Integration (optional)
LINKEDIN_BOT_WEBHOOK_URL=http://localhost:3001/api/resume-ready
LINKEDIN_BOT_API_KEY=

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
